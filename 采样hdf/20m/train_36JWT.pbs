#!/bin/bash
#PBS -N train_36JWT_anytime_20m
#PBS -q gpu
#PBS -l nodes=1:ppn=24:gpus=1
#PBS -l mem=400gb
#PBS -l walltime=48:00:00
#PBS -j oe
#PBS -M 1510733403@qq.com
#PBS -m ae

set -eo pipefail

cd /public/home/xwlin/Data/songyibo/dataset_down_from_GEE/36JWT/code/AnytimeFormer-main/preprocess/20m

source /public/home/xwlin/miniconda3/bin/activate anytime
export LD_LIBRARY_PATH=/public/home/xwlin/miniconda3/envs/anytime/lib:$LD_LIBRARY_PATH
export PYTHONPATH=/public/home/xwlin/Data/songyibo/dataset_down_from_GEE/36JWT/code/AnytimeFormer-main:$PYTHONPATH

echo "=========================================="
echo "Train 36JWT AnytimeFormer (20m)"
echo "=========================================="
echo "Job started at: $(date)"
echo "Running on node: $(hostname)"
echo "Working directory: $(pwd)"
echo "Python: $(which python)"
echo "=========================================="
echo "GPU info:"
nvidia-smi
echo "=========================================="
echo "Config path: ./AnytimeFormer-36JWT-40%-r8-128-wTV.yaml"
echo "Train HDF: /public/home/xwlin/Data/songyibo/dataset_for_model/36JWT/hdf/anytime.hdf"
echo "Work dir: /public/home/xwlin/Data/songyibo/dataset_for_model/36JWT/work_dir/anytime_20m_train"
echo "Ref S2 (20m): /public/home/xwlin/Data/songyibo/dataset_down_from_GEE/36JWT/S2_remove_cloud/20m/S2_L2A_20240901_20m.tif"
echo "=========================================="

python -u main.py \
    --mode train \
    --config_path ./AnytimeFormer-36JWT-40%-r8-128-wTV.yaml \
    --original_dataset_path /public/home/xwlin/Data/songyibo/dataset_for_model/36JWT/hdf/anytime.hdf \
    --work_dir /public/home/xwlin/Data/songyibo/dataset_for_model/36JWT/work_dir/anytime_20m_train \
    --ref_tif_path /public/home/xwlin/Data/songyibo/dataset_down_from_GEE/36JWT/S2_remove_cloud/20m/S2_L2A_20240901_20m.tif \
    --device cuda

EXIT_CODE=$?

echo "=========================================="
echo "Job finished at: $(date)"
echo "Exit code: $EXIT_CODE"
echo "=========================================="

exit $EXIT_CODE
